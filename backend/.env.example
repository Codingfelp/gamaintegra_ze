# =============================================================================
# EXEMPLO DE CONFIGURAÇÃO - BACKEND
# =============================================================================
# Copie este arquivo para .env e preencha com suas credenciais
# NÃO COMMITE o arquivo .env no repositório

# Banco de Dados MySQL (Railway)
MYSQL_HOST=mainline.proxy.rlwy.net
MYSQL_PORT=52996
MYSQL_USER=root
MYSQL_PASSWORD=SUA_SENHA_AQUI
MYSQL_DATABASE=railway

# URL do Backend (ajustar conforme ambiente)
# Desenvolvimento: http://localhost:8001
# Produção: https://seu-dominio.com
REACT_APP_BACKEND_URL=http://localhost:8001
