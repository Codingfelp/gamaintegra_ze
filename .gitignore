# =============================================================================
# GITIGNORE - Integrador Zé Delivery
# =============================================================================

# Dependências
node_modules/
venv/
__pycache__/
*.pyc

# Arquivos de ambiente (contém senhas)
.env
.env.local
.env.production

# Logs
logs/
*.log

# Perfis do Chrome (contém cookies de sessão)
zedelivery-clean/profile-ze-*/
zedelivery-clean/chrome-profile/
zedelivery-clean/cookies-backup/

# Arquivos temporários
*.tmp
*.temp
.DS_Store
Thumbs.db

# Build do frontend
frontend/build/
frontend/node_modules/

# Cache
.cache/
*.cache

# IDE
.vscode/
.idea/
*.swp
*.swo

# Arquivos de configuração do webhook (contém secrets)
backend/webhook_config.json

# Screenshots de debug
*.png

# Arquivos de teste
test_reports/
*.test.js
*.spec.js

# MySQL local (se usar)
mysql_data/
mysql_logs/

# Documentação gerada
docs/*.html

# Arquivos grandes de HTML (usados para debug de seletores)
html_seletores/
seletores_novos/
node_modules/chromium/lib/chromium/chrome-linux/chrome
zedelivery-clean/node_modules/electron/dist/electron
zedelivery-clean/node_modules/chromium/lib/chromium/chrome-linux/chrome
