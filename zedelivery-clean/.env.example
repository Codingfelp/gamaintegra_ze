# =============================================================================
# CONFIGURAÇÃO DO SCRAPER (opcional)
# =============================================================================
# A maioria das configurações está em configuracao.json
# Este arquivo é para variáveis de ambiente opcionais

# Caminho do Chromium (se diferente do padrão)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Modo headless (true para sem interface, false para debug)
# HEADLESS=true
